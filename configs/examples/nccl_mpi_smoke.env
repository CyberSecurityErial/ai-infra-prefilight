# Scenario
TARGET=nccl_mpi
TEST_LEVEL=smoke

# Nodes
NODES_FILE=configs/examples/nodes/two_nodes.nodes
UPDATE_ETC_HOSTS=1

# SSH
SSH_PORT=12222
SSH_TIMEOUT=5

# Runtime timeout
COMMAND_TIMEOUT=20
MPI_TIMEOUT=25
NCCL_TIMEOUT=60

# Network
CONTROL_IF_CIDR=10.104.144.0/21
CONTROL_IF_NAME=
DATA_IF_NAME=bond0
DATA_IF_CIDR=
TCP_CALLBACK_PORT=29500

# MPI
MPI_BIN=mpirun
MPI_HOSTFILE=/tmp/preflight_mpi_hostfile
MPI_NP=2
MPI_LOCAL_NP=2
MPI_ALLOW_RUN_AS_ROOT=1
MPI_DISABLE_OPENIB_BTL=1
MPI_NO_TREE_SPAWN=1
MPI_VERBOSE=0

# NCCL
NCCL_TEST_BIN=/opt/nccl-tests/build/all_reduce_perf
NCCL_DEBUG=INFO
NCCL_SOCKET_IFNAME=bond0
NCCL_MIN_BYTES=8M
NCCL_MAX_BYTES=128M
NCCL_STEP_FACTOR=2
NCCL_GPUS_PER_PROCESS=1

# Checks
RUN_SSH_CHECK=1
RUN_ROUTE_CHECK=1
RUN_TCP_CHECK=1
RUN_NCCL_STANDALONE_CHECK=1
RUN_MPI_STANDALONE_CHECK=1
RUN_INTEGRATION_CHECK=1

# Logging
LOG_ROOT=logs

# Cleanup
PREFLIGHT_CLEAN_MPI_TMP=0
PREFLIGHT_CLEAN_LEGACY_PATTERNS=0
PREFLIGHT_CLEAN_SCOPE=all_preflight
