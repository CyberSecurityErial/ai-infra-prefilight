TARGET=nccl_srun
TEST_LEVEL=smoke

COMMAND_TIMEOUT=20
NCCL_TIMEOUT=60

NCCL_TEST_BIN=/opt/nccl-tests/build/all_reduce_perf
NCCL_DEBUG=INFO
NCCL_SOCKET_IFNAME=bond0
NCCL_MIN_BYTES=8M
NCCL_MAX_BYTES=128M
NCCL_STEP_FACTOR=2
NCCL_GPUS_PER_PROCESS=1

SLURM_PARTITION=
SLURM_NNODES=2
SLURM_NTASKS=2
LOG_ROOT=logs
