TARGET=nccl_torchrun
TEST_LEVEL=smoke

NODES_FILE=configs/examples/nodes/two_nodes.nodes
UPDATE_ETC_HOSTS=0

SSH_PORT=22
SSH_TIMEOUT=5
COMMAND_TIMEOUT=20
NCCL_TIMEOUT=60

NCCL_TEST_BIN=/opt/nccl-tests/build/all_reduce_perf
NCCL_DEBUG=INFO
NCCL_SOCKET_IFNAME=bond0
NCCL_MIN_BYTES=8M
NCCL_MAX_BYTES=128M
NCCL_STEP_FACTOR=2
NCCL_GPUS_PER_PROCESS=1

TORCHRUN_NNODES=2
TORCHRUN_NPROC_PER_NODE=1
LOG_ROOT=logs
